{
    "name": "meeting-assistant-backend",
    "version": "1.0.0",
    "description": " meeting assistant backend with Express and TypeScript",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon --exec ts-node src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "migrate": "prisma migrate deploy",
        "migrate:dev": "prisma migrate dev",
        "seed": "ts-node prisma/seed.ts",
        "prisma:generate": "prisma generate",
        "prisma:studio": "prisma studio",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "ai",
        "meeting",
        "assistant",
        "express",
        "typescript",
        "openai"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@bull-board/api": "^5.21.4",
        "@bull-board/express": "^5.21.4",
        "@prisma/client": "^5.22.0",
        "@sendgrid/mail": "^8.1.4",
        "assemblyai": "^4.23.1",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.20.3",
        "compression": "^1.7.5",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "googleapis": "^171.4.0",
        "helmet": "^8.0.0",
        "ioredis": "^5.4.2",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^6.9.16",
        "openai": "^4.77.3",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.13.1",
        "socket.io": "^4.8.1",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.10.2",
        "@types/nodemailer": "^6.4.17",
        "@types/passport": "^1.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/pg": "^8.11.10",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.18.1",
        "@typescript-eslint/parser": "^8.18.1",
        "eslint": "^9.17.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "prettier": "^3.4.2",
        "prisma": "^5.22.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"

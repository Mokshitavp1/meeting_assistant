# ============================================
# APPLICATION SETTINGS
# ============================================

# Application environment (development, production, staging)
NODE_ENV=development

# Server port - the port on which the Express server will listen
PORT=3000

# API base URL - used for generating links in emails, webhooks, etc.
API_BASE_URL=http://localhost:3000

# Frontend URL - used for CORS and redirect URLs
FRONTEND_URL=http://localhost:5173


# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/meeting_assistant

# Database connection pool settings (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10


# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis connection URL for caching and session storage
# Format: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# Redis host (alternative to REDIS_URL)
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis database number (0-15)
REDIS_DB=0


# ============================================
# JWT & AUTHENTICATION
# ============================================

# JWT secret for access tokens - use a strong random string (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-this-in-production

# JWT secret for refresh tokens - use a different strong random string
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this-in-production

# Access token expiration time (e.g., 15m, 1h, 1d)
JWT_ACCESS_EXPIRATION=15m

# Refresh token expiration time (e.g., 7d, 30d)
JWT_REFRESH_EXPIRATION=7d

# Password reset token expiration time (in minutes)
PASSWORD_RESET_EXPIRATION=60


# ============================================
# OPENAI CONFIGURATION
# ============================================

# OpenAI API key for AI features (transcription, summarization, insights)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# OpenAI organization ID (optional)
OPENAI_ORG_ID=

# OpenAI model for transcription (whisper-1)
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# OpenAI model for text generation (gpt-4, gpt-3.5-turbo, etc.)
OPENAI_CHAT_MODEL=gpt-4-turbo-preview

# Maximum tokens for AI responses
OPENAI_MAX_TOKENS=2000

# Temperature for AI responses (0.0 - 2.0, lower = more deterministic)
OPENAI_TEMPERATURE=0.7


# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email service provider (sendgrid or smtp)
EMAIL_PROVIDER=sendgrid

# SendGrid API key
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Sender email address
EMAIL_FROM=noreply@yourdomain.com

# Sender name
EMAIL_FROM_NAME=AI Meeting Assistant

# SMTP Configuration (if using SMTP instead of SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password


# ============================================
# AWS S3 CONFIGURATION (for file storage)
# ============================================

# AWS region where S3 bucket is located
AWS_REGION=us-east-1

# AWS access key ID
AWS_ACCESS_KEY_ID=your-aws-access-key-id

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# S3 bucket name for storing meeting recordings and files
AWS_S3_BUCKET=meeting-assistant-uploads

# S3 bucket URL (optional, for custom domains)
AWS_S3_BUCKET_URL=https://meeting-assistant-uploads.s3.amazonaws.com

# CloudFront distribution URL (optional, for CDN)
AWS_CLOUDFRONT_URL=


# ============================================
# GOOGLE CALENDAR API
# ============================================

# Google OAuth2 client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth2 client secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth2 redirect URI
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Calendar API key (optional)
GOOGLE_API_KEY=


# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins for CORS (comma-separated list)
# In production, specify exact domains: https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allow credentials in CORS requests
CORS_CREDENTIALS=true


# ============================================
# RATE LIMITING
# ============================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# Time window for rate limiting (in minutes)
RATE_LIMIT_WINDOW_MINUTES=15

# Rate limit for login attempts
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15


# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum file size for uploads (in bytes)
# 50MB = 52428800, 100MB = 104857600, 500MB = 524288000
MAX_FILE_SIZE=104857600

# Maximum file size for audio/video recordings (in bytes)
MAX_RECORDING_SIZE=524288000

# Allowed file types for general uploads (comma-separated)
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.jpg,.jpeg,.png,.mp3,.mp4,.wav,.m4a

# Allowed audio file types (comma-separated)
ALLOWED_AUDIO_TYPES=.mp3,.wav,.m4a,.webm,.ogg

# Upload directory (for local storage, if not using S3)
UPLOAD_DIR=./uploads


# ============================================
# SOCKET.IO CONFIGURATION
# ============================================

# Socket.IO connection timeout (in milliseconds)
SOCKET_TIMEOUT=20000

# Socket.IO ping interval (in milliseconds)
SOCKET_PING_INTERVAL=25000

# Socket.IO ping timeout (in milliseconds)
SOCKET_PING_TIMEOUT=60000


# ============================================
# BULLMQ / JOB QUEUE CONFIGURATION
# ============================================

# Number of concurrent jobs to process
QUEUE_CONCURRENCY=5

# Job timeout (in milliseconds)
QUEUE_JOB_TIMEOUT=300000

# Maximum number of job attempts on failure
QUEUE_MAX_ATTEMPTS=3

# Delay between retry attempts (in milliseconds)
QUEUE_RETRY_DELAY=5000


# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# Log format (json or simple)
LOG_FORMAT=json

# Enable file logging
LOG_TO_FILE=true

# Log directory
LOG_DIR=./logs

# Maximum log file size before rotation (e.g., 20m, 10k)
LOG_MAX_SIZE=20m

# Maximum number of log files to keep
LOG_MAX_FILES=14d


# ============================================
# SECURITY SETTINGS
# ============================================

# Enable helmet security headers
HELMET_ENABLED=true

# Session secret for encrypting session cookies
SESSION_SECRET=your-super-secret-session-key-change-this

# Cookie secure flag (set to true in production with HTTPS)
COOKIE_SECURE=false

# Cookie same-site policy (strict, lax, none)
COOKIE_SAME_SITE=lax

# Maximum number of login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration (in minutes)
ACCOUNT_LOCKOUT_DURATION=30


# ============================================
# FEATURE FLAGS
# ============================================

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable SMS notifications (requires Twilio or similar service)
ENABLE_SMS_NOTIFICATIONS=false

# Enable Google Calendar integration
ENABLE_GOOGLE_CALENDAR=true

# Enable real-time transcription
ENABLE_REALTIME_TRANSCRIPTION=true

# Enable analytics tracking
ENABLE_ANALYTICS=false


# ============================================
# WEBHOOK & INTEGRATIONS
# ============================================

# Webhook secret for validating incoming webhooks
WEBHOOK_SECRET=your-webhook-secret-key

# Slack webhook URL (optional)
SLACK_WEBHOOK_URL=

# Discord webhook URL (optional)
DISCORD_WEBHOOK_URL=


# ============================================
# DEVELOPMENT & DEBUGGING
# ============================================

# Enable debug mode (verbose logging, detailed error messages)
DEBUG=false

# Enable API documentation (Swagger/OpenAPI)
ENABLE_API_DOCS=true

# Enable database query logging
DB_LOGGING=false

# Seed database on startup (development only)
AUTO_SEED_DB=false